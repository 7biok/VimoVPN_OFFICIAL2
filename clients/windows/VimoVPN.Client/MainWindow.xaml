<Window x:Class="VimoVPN.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VimoVPN Desktop"
        Width="1180"
        Height="860"
        MinWidth="980"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#1977FF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#202B3D" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#171D2A" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="BorderBrush" Value="#263246" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#060A12" Offset="0" />
                <GradientStop Color="#0D1A31" Offset="0.58" />
                <GradientStop Color="#0F57C8" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="28" Background="#0C1018" CornerRadius="32" BorderBrush="#1B2432" BorderThickness="1">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="VimoVPN" Foreground="White" FontSize="34" FontFamily="Bahnschrift SemiBold" />
                        <TextBlock Text="Windows client with Telegram login and automatic best-server selection"
                                   Foreground="#8EA2C3"
                                   Margin="0,6,0,0"
                                   FontSize="14" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="16,10"
                            Background="#162034"
                            CornerRadius="16"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="API" Foreground="#7D92B3" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ApiBaseUrl}" Foreground="White" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,12,28,0">
                        <TextBlock Text="Login through Telegram" Foreground="White" FontSize="28" FontFamily="Bahnschrift SemiBold" />
                        <TextBlock Text="Request a one-time code, open the bot link, confirm login, and the desktop session will bind to your Telegram profile."
                                   TextWrapping="Wrap"
                                   Foreground="#95A9C8"
                                   Margin="0,12,0,28"
                                   FontSize="16" />

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="One-time code" Foreground="#8EA2C3" FontSize="14" />
                                <TextBlock Text="{Binding LoginCodeDisplay}"
                                           Foreground="White"
                                           FontSize="44"
                                           FontFamily="Bahnschrift SemiBold"
                                           Margin="0,14,0,10" />
                                <TextBlock Text="{Binding AuthStatusText}" Foreground="#C1CDE1" FontSize="14" TextWrapping="Wrap" />
                                <WrapPanel Margin="0,24,0,0">
                                    <Button Content="Request Code" Click="RequestCode_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="Open Telegram" Click="OpenTelegram_Click" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Connection flow" Foreground="White" FontSize="22" FontFamily="Bahnschrift SemiBold" />
                            <TextBlock Text="1. The app requests a temporary login code." Margin="0,22,0,8" Foreground="#D4DEF0" />
                            <TextBlock Text="2. Telegram opens @VimoVPN_bot with /start login_CODE." Margin="0,0,0,8" Foreground="#D4DEF0" />
                            <TextBlock Text="3. After confirmation the app receives a bearer token." Margin="0,0,0,8" Foreground="#D4DEF0" />
                            <TextBlock Text="4. Active keys are loaded, endpoints are pinged, and the best one is used for sing-box." Margin="0,0,0,8" Foreground="#D4DEF0" TextWrapping="Wrap" />
                            <TextBlock Text="5. Traffic and expiry are refreshed from your VimoVPN backend." Margin="0,0,0,8" Foreground="#D4DEF0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,18,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding UserDisplayName}" Foreground="White" FontSize="26" FontFamily="Bahnschrift SemiBold" />
                                    <TextBlock Text="{Binding ProfileMetaText}" Foreground="#97ABC9" FontSize="14" Margin="0,8,0,8" />
                                    <TextBlock Text="{Binding TrafficSummaryText}" Foreground="#D6E1F2" FontSize="16" />
                                    <TextBlock Text="{Binding ConnectionStatusText}" Foreground="#7AC0FF" FontSize="14" Margin="0,12,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Content="Refresh" Click="RefreshProfile_Click" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="Connect Best" Click="ConnectBest_Click" Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="Disconnect" Click="Disconnect_Click" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="Reset Login" Click="ResetLogin_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Current route" Foreground="White" FontSize="22" FontFamily="Bahnschrift SemiBold" />
                                <TextBlock Text="{Binding SelectedServerName}" Foreground="#7AC0FF" FontSize="18" Margin="0,18,0,6" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedServerDetails}" Foreground="#D2DCEC" FontSize="14" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <DockPanel>
                            <TextBlock Text="Available subscriptions / servers"
                                       Foreground="White"
                                       FontSize="22"
                                       FontFamily="Bahnschrift SemiBold"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,18" />

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ServerCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="330"
                                                    Margin="0,0,18,18"
                                                    Padding="18"
                                                    Background="#111827"
                                                    BorderBrush="#243044"
                                                    BorderThickness="1"
                                                    CornerRadius="22">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="20" FontFamily="Bahnschrift SemiBold" />
                                                    <TextBlock Text="{Binding StatusText}" Foreground="#85B6FF" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding TrafficText}" Foreground="#D3DEEF" FontSize="13" Margin="0,12,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding PingText}" Foreground="#A2B4D1" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Key.ExpiresAt}" Foreground="#A2B4D1" FontSize="13" Margin="0,8,0,0" />
                                                    <TextBlock Text="{Binding Key.PingTarget}" Foreground="#7F91AE" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                                    <WrapPanel Margin="0,18,0,0">
                                                        <Button Content="Connect"
                                                                Tag="{Binding Key}"
                                                                Click="ConnectSpecific_Click"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
